{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build All CPP",
            "type": "shell",
            "command": "cl.exe",
            "args": [
                "main.cpp",
                "utils.cpp",
                "bubble_sort.cpp",
                "insertion_sort.cpp",
                "selection_sort.cpp",
                "merge_sort.cpp",
                "quick_sort.cpp",
                "heap_sort.cpp",
                "/EHsc",
                "/std:c++17",
                "/nologo",
                "/Fe:${workspaceFolder}\\main.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "detail": "Compile all sorting project files"
        },
        {
            "label": "Run Program",
            "type": "process",
            "command": "${workspaceFolder}\\main.exe",
            "dependsOn": "Build All CPP",
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "clear": true
            },
            "detail": "Run program in VS Code terminal"
        }
    ]
}