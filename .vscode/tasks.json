{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build All CPP",
            "type": "shell",
            "command": "cl.exe",
            "args": [
                "main.cpp",
                "utils.cpp",
                "bubble_sort.cpp",
                "insertion_sort.cpp",
                "selection_sort.cpp",
                "merge_sort.cpp",
                "quick_sort.cpp",
                "heap_sort.cpp",
                "/EHsc",
                "/nologo",
                "/Fe${workspaceFolder}\\main.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "detail": "Compile all sorting project files"
        },
        {
            "label": "Run main.exe (Console Output)",
            "type": "shell",
            "command": "cmd.exe",
            "args": [
                "/k",
                "${workspaceFolder}\\main.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "dependsOn": "Build All CPP",
            "detail": "Run the benchmark and keep the console open"
        },
        {
            "type": "cppbuild",
            "label": "C/C++: cl.exe build active file",
            "command": "cl.exe",
            "args": [
                "/Zi",
                "/EHsc",
                "/nologo",
                "/Fe${fileDirname}\\${fileBasenameNoExtension}.exe",
                "${file}"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        }
    ]
}